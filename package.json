{
  "name": "konto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:parser:benchmark": "vitest run tests/parser/benchmark.test.ts",
    "test:rls": "vitest run __tests__/rls",
    "test:rls:report": "vitest run __tests__/rls --reporter=json --outputFile=tests/security/rls-results.json && node scripts/generate-rls-report.mjs",
    "parser:golden:generate": "node scripts/generate-parser-golden-dataset.mjs",
    "test:e2e": "playwright test --grep-invert @slow",
    "test:e2e:all": "playwright test",
    "test:e2e:slow": "playwright test --grep @slow",
    "e2e:web": "pnpm exec supabase start && pnpm exec next dev --turbopack -H 127.0.0.1 -p 4173",
    "lighthouse:pages": "node ./scripts/lighthouse-key-pages.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:types": "node scripts/supabase-gen-types.mjs",
    "prepare": "husky",
    "postinstall": "node scripts/supabase-gen-types.mjs --local --tolerant"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "supabase"
    ],
    "overrides": {
      "basic-ftp": "^5.3.1",
      "ip-address": "^10.1.1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@thednp/dommatrix": "^3.0.4",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "libphonenumber-js": "^1.12.42",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.6.205",
    "react": "19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.73.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@next/eslint-plugin-next": "15.5.15",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lighthouse": "^13.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.5.3",
    "supabase": "^2.93.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.24.0",
    "vitest": "^4.1.5"
  }
}
