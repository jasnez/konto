confirmModulesPurge=false
supportedArchitectures.os[]=win32
supportedArchitectures.cpu[]=arm64
supportedArchitectures.cpu[]=x64
# Use a flat (hoisted) node_modules layout instead of pnpm's default
# symlinked virtual store. Vercel's serverless packaging step rejects
# functions whose traced files live in symlinked directories
# (INVALID_FUNCTION_LAYOUT). pdfjs-dist's pdf.worker.mjs sits in
# node_modules/.pnpm/.../legacy/build/ under the default layout, which
# triggered the error. With node-linker=hoisted, packages are placed at
# real paths under node_modules/ — the canonical Vercel + pnpm fix.
node-linker=hoisted
