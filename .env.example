# Template za env varijable. Oba fajla (.env.local, .env.development.local) su
# u .gitignore. Pravila ucitavanja (Next.js):
#   - `pnpm dev`   -> .env.development.local > .env.local > .env.development > .env
#   - `pnpm build` -> .env.production.local  > .env.local > .env.production  > .env
#
# Preporuka za ovaj projekat:
#   .env.development.local  — LOKALNI Supabase (http://127.0.0.1:54321), koristi se
#                             automatski u `pnpm dev`
#   .env.local              — cloud/Vercel preview ili prod keys (fallback)
#
# Vercel ucitava iz svoje "Environment Variables" sekcije; ovi fajlovi tamo ne
# postoje.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=
