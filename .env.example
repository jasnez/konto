# Template za env varijable. Fajlovi .env.local i .env.development.local su u
# .gitignore. Pravila ucitavanja (Next.js):
#   - `pnpm dev`   -> .env.development.local > .env.local > .env.development > .env
#   - `pnpm build` -> .env.production.local  > .env.local > .env.production  > .env
#
# Preporuka za ovaj projekat:
#   .env.development.local  — LOKALNI Supabase (http://127.0.0.1:54321), koristi
#                             se automatski u `pnpm dev`
#   .env.local              — cloud/Vercel preview ili prod keys (fallback)
#
# Vercel ucitava iz svoje "Environment Variables" sekcije; ovi fajlovi tamo ne
# postoje.

# --- Obavezno (app runtime) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=

# --- Opcionalno: integracioni RLS testovi (`pnpm test -- __tests__/rls`) ---
# Postavi na '1' da ukljucis integracione testove koji zahtijevaju lokalni
# Supabase stack. Bez ovoga testovi se preskacu.
# RUN_INTEGRATION_TESTS=1
# SUPABASE_URL_TEST=http://127.0.0.1:54321
# SUPABASE_ANON_KEY_TEST=
# SUPABASE_SERVICE_KEY_TEST=

# --- Opcionalno: Playwright E2E ---
# E2E_BASE_URL=http://localhost:3000

# --- Gemini 2.5 Flash-Lite (OCR fiskalnog računa + LLM parser PDF izvoda) ---
# API ključ za Gemini 2.5 Flash-Lite:
#   - /skeniraj     — native image OCR + JSON ekstrakcija sa fiskalnog računa
#   - F2-E2-T3      — LLM parser redactovanog teksta PDF bankovnog izvoda
# Bez ovog ključa /skeniraj radi uz ručni unos, a PDF import vraća grešku.
# Na Vercel-u postaviti u Project Settings → Environment Variables.
# Dobavi na https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# --- Opcionalno: OCR fallback za image-PDF izvode (Mistral OCR — F2-E2-T4) ---
# Koristi se kada PDF nema tekstualni sloj (scanned izvod). Gemini ga ne
# zamjenjuje jer radi OCR slike, a ne višestraničnog PDF-a u jednom pozivu.
# MISTRAL_API_KEY=

# --- Cron zaštita (obavezno u produkciji) ---
# Bearer token za autentifikaciju cron endpointa (/api/cron/*) i Supabase
# Edge Function-a (hard-delete-accounts). Generiši sa:
#   openssl rand -hex 32
# Na Vercelu: Project Settings → Environment Variables
# Na Supabase: Dashboard → Edge Functions → Secrets
# CRON_SECRET=

# --- Brisanje naloga (obavezno u produkciji) ---
# Secret za potpisivanje JWT cancel-deletion tokena. Generiši sa:
#   openssl rand -hex 32
# ACCOUNT_DELETION_TOKEN_SECRET=

# --- Email (obavezno za produkciju account deletion flow-a) ---
# Resend API ključ i sender adresa za slanje email-a pri brisanju naloga.
# Bez ovih varijabli, deletion flow preskače email slanje u dev modu.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@example.com

# --- Closed beta — invite-only sign-up (F4-E2-T1) ---
# Set to 'true' to require an invite code on /prijava and /registracija.
# When unset (default), the auth flow is open. Codes are generated via
# `pnpm tsx scripts/generate-invite-codes.mjs N`.
# ENABLE_INVITES=

# --- Admin email (opciono, za /admin/invites) ---
# Hardcoded admin email. /admin/* routes 404 unless the authenticated user's
# email matches. Leaving unset disables the admin namespace entirely.
# ADMIN_EMAIL=

# --- Opcionalno: postinstall ---
# Ako je '1', scripts/supabase-gen-types.mjs preskace generisanje (korisno
# na CI-u gdje lokalni Supabase nije dostupan, iako skripta ima i --tolerant).
# SUPABASE_GEN_SKIP=1

# --- Sentry (opciono — observability za beta) ---
# PR-2: error tracking. Bez NEXT_PUBLIC_SENTRY_DSN cijeli Sentry SDK je
# no-op (nema init-a, nema network requests-a, nema overhead-a). Setup:
#   1) Kreiraj Sentry account (free tier: 5K errors / 100K spans / mjesec)
#   2) Kreiraj 'konto' projekat u Sentry → kopiraj DSN
#   3) Postavi NEXT_PUBLIC_SENTRY_DSN u Vercel env (production + preview)
# DSN se sigurno emituje u client bundle — to je dizajn (browser SDK ga
# treba). Sve PII u event payload-u se redaktuje u beforeSend hook-u
# (vidi lib/observability/sentry-scrub.ts).
# NEXT_PUBLIC_SENTRY_DSN=

# --- Sentry source map upload (opciono — samo u CI / Vercel build) ---
# Bez ovih varijabli build još uvijek prolazi i errori se i dalje hvataju,
# ali stack traces neće biti symbolikovani (vidjet ćeš minified imena).
# Generisanje tokena: Sentry → Settings → Auth Tokens → New Token
# (scope: project:releases). NIKAD ne commit-uj u repo.
# SENTRY_ORG=
# SENTRY_PROJECT=konto
# SENTRY_AUTH_TOKEN=
